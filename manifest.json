{
  "manifest_version": 3,
  "name": "Twitch Multi-Account",
  "version": "1.0.1",
  "description": "Switch between multiple Twitch accounts in the same window using automatic cookie swapping.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "cookies",
    "scripting"
  ],
  "host_permissions": [
    "*://*.twitch.tv/*"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Twitch Multi-Account"
  },
  "background": {
    "service_worker": "background/background.js"
  }
}
